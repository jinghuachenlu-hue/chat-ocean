<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Discord-Style Chat</title>
<style>
/* ----- General Styles ----- */
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #313338;
    color: white;
    display: flex;
    height: 100vh;
}

/* ----- Sidebar ----- */
#sidebar {
    width: 220px;
    background: #2b2d31;
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

#sidebar h2 {
    margin-top: 0;
    color: #ffffff;
}

#sidebar input {
    padding: 8px;
    border: none;
    border-radius: 3px;
    background: #1e1f22;
    color: white;
}

/* ----- Chat Area ----- */
#chatArea {
    flex: 1;
    display: flex;
    flex-direction: column;
}

#messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
}

.message {
    margin-bottom: 10px;
}

.username {
    color: #5865f2;
    font-weight: bold;
}

/* ----- Input Bar ----- */
#inputBar {
    display: flex;
    padding: 10px;
    background: #383a40;
}

#inputBar input {
    flex: 1;
    padding: 10px;
    background: #1e1f22;
    border: none;
    color: white;
    border-radius: 3px;
}

#inputBar button {
    margin-left: 10px;
    padding: 10px;
    background: #5865f2;
    border: none;
    color: white;
    cursor: pointer;
    border-radius: 3px;
}
</style>
</head>
<body>

<div id="sidebar">
<h2>Discord Chat</h2>
<input id="username" placeholder="Enter your username">
<button onclick="setName()">Set Name</button>
</div>

<div id="chatArea">
<div id="messages"></div>
<div id="inputBar">
<input id="messageInput" placeholder="Type a message">
<button onclick="sendMessage()">Send</button>
</div>
</div>

<script type="module">
// ----- Firebase Imports -----
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, addDoc, onSnapshot, query, orderBy } 
from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

// ----- Your Firebase Config -----
const firebaseConfig = {
  apiKey: "AIzaSyCmCYWwuIBqpoXjx7CsdAvTd6j7GukG4zA",
  authDomain: "chat-e7ede.firebaseapp.com",
  projectId: "chat-e7ede",
  storageBucket: "chat-e7ede.firebasestorage.app",
  messagingSenderId: "261404204759",
  appId: "1:261404204759:web:091845f91490d7ec735a92",
  measurementId: "G-S9S3F10VHR"
};

// ----- Initialize Firebase -----
const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

// ----- Username Setup -----
let username = "Guest";
window.setName = function() {
    const input = document.getElementById("username").value;
    if(input.trim() !== "") username = input.trim();
}

// ----- Send Message -----
window.sendMessage = async function() {
    const textInput = document.getElementById("messageInput");
    const text = textInput.value.trim();
    if(text === "") return;
    await addDoc(collection(db, "messages"), {
        user: username,
        text: text,
        time: Date.now()
    });
    textInput.value = "";
}

// ----- Load Messages in Real-Time -----
const q = query(collection(db, "messages"), orderBy("time"));
onSnapshot(q, (snapshot) => {
    const messagesDiv = document.getElementById("messages");
    messagesDiv.innerHTML = "";
    snapshot.forEach(doc => {
        const m = doc.data();
        const msgEl = document.createElement("div");
        msgEl.classList.add("message");
        msgEl.innerHTML = `<span class="username">${m.user}</span>: ${m.text}`;
        messagesDiv.appendChild(msgEl);
    });
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
});
</script>

</body>
</html>
